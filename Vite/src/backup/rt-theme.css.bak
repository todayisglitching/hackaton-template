@import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Space+Grotesk:wght@400;500;600;700&display=swap');

:root,
.light,
.default,
[data-theme='light'],
[data-theme='default'] {
  --accent: #ff4f12;
  --accent-strong: #d94200;
  --accent-soft: #fff0e8;
  --accent-secondary: #7c4dff;
  --background: #f7f5f1;
  --foreground: #161616;
  --surface: rgba(255, 255, 255, 0.82);
  --surface-secondary: rgba(255, 255, 255, 0.64);
  --surface-tertiary: #f0ece7;
  --border: rgba(22, 22, 22, 0.1);
  --border-strong: rgba(22, 22, 22, 0.18);
  --muted: #6d655f;
  --success: #138a5a;
  --warning: #f3a81f;
  --danger: #cf4436;
  --radius: 24px;
  --radius-sm: 18px;
  --font-sans: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
  --font-display: 'Fraunces', ui-serif, Georgia, serif;
}

body {
  font-family: var(--font-sans);
  color: var(--foreground);
  background:
    radial-gradient(circle at top left, rgba(255, 79, 18, 0.16), transparent 34%),
    radial-gradient(circle at 86% 14%, rgba(124, 77, 255, 0.08), transparent 24%),
    linear-gradient(180deg, #fff8f1 0%, #f7f5f1 55%, #efeae3 100%);
}

.rt-landing {
  position: relative;
  overflow: hidden;
}

.rt-dashboard-bg {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 79, 18, 0.1), transparent 30%),
    radial-gradient(circle at 0% 20%, rgba(124, 77, 255, 0.06), transparent 26%);
}

.rt-mesh {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(to right, rgba(22, 22, 22, 0.02) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(22, 22, 22, 0.02) 1px, transparent 1px);
  background-size: 28px 28px;
  mask-image: radial-gradient(circle at 50% 20%, #000 55%, transparent 90%);
}

.rt-grid {
  background-image:
    linear-gradient(to right, rgba(22, 22, 22, 0.03) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(22, 22, 22, 0.03) 1px, transparent 1px);
  background-size: 44px 44px;
  mask-image: radial-gradient(circle at 50% 20%, #000 55%, transparent 84%);
}

.rt-orbit {
  position: absolute;
  right: -120px;
  top: -100px;
  z-index: 0;
  width: 620px;
  height: 620px;
  border-radius: 999px;
  background:
    radial-gradient(circle at 30% 30%, rgba(255, 79, 18, 0.42), transparent 36%),
    radial-gradient(circle at 70% 60%, rgba(124, 77, 255, 0.2), transparent 40%),
    radial-gradient(circle at 55% 55%, rgba(255, 255, 255, 0.5), transparent 58%);
  filter: blur(14px);
  animation: rtFloat 9s ease-in-out infinite;
}

.rt-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.8rem 1rem;
  border: 1px solid rgba(255, 255, 255, 0.55);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.68);
  box-shadow: 0 10px 28px rgba(22, 22, 22, 0.07);
  backdrop-filter: blur(18px);
}

.rt-logo-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 52px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 14px 30px rgba(22, 22, 22, 0.08);
}

.rt-card {
  border: 1px solid rgba(255, 255, 255, 0.72);
  border-radius: var(--radius);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.68));
  box-shadow: 0 18px 44px rgba(22, 22, 22, 0.08);
  backdrop-filter: blur(20px);
}

.rt-card-soft {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(248, 244, 239, 0.7));
  box-shadow: 0 10px 28px rgba(22, 22, 22, 0.06);
}

.rt-pill {
  border: 1px solid rgba(255, 79, 18, 0.14);
  background: rgba(255, 255, 255, 0.9);
  color: var(--foreground);
}

.rt-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.45rem 0.85rem;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.72);
  color: var(--foreground);
}

.rt-btn {
  border-radius: 999px;
  padding: 0.72rem 1.15rem;
  font-weight: 600;
  transition: transform 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease, border-color 0.18s ease;
}

.rt-btn:hover {
  transform: translateY(-1px);
}

.rt-btn-primary {
  background: linear-gradient(135deg, var(--accent) 0%, #ff7a1a 100%);
  color: #fff;
  box-shadow: 0 16px 30px rgba(255, 79, 18, 0.28);
}

.rt-btn-secondary {
  background: rgba(255, 255, 255, 0.85);
  color: var(--foreground);
  border: 1px solid var(--border);
}

.rt-btn-accent {
  background: linear-gradient(135deg, var(--accent-secondary) 0%, #5435c9 100%);
  color: #fff;
  box-shadow: 0 16px 30px rgba(124, 77, 255, 0.18);
}

.rt-display {
  font-family: var(--font-display);
  letter-spacing: -0.04em;
}

.rt-kicker {
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--accent);
}

.rt-divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(22, 22, 22, 0.12), transparent);
}

.rt-stat {
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: rgba(255, 255, 255, 0.66);
  padding: 1rem;
}

.rt-nav-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.72rem 1rem;
  border: 1px solid transparent;
  border-radius: 999px;
  color: var(--muted);
  transition: color 0.18s ease, background-color 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
}

.rt-nav-link:hover {
  color: var(--foreground);
  background: rgba(255, 255, 255, 0.62);
}

.rt-nav-link-active {
  color: var(--foreground);
  border-color: rgba(255, 79, 18, 0.16);
  background: rgba(255, 79, 18, 0.1);
}

.rt-sidebar {
  min-width: 0;
}

.rt-auth-shell {
  position: relative;
  display: grid;
  gap: 1.5rem;
  align-items: stretch;
}

.rt-auth-grid {
  display: grid;
  gap: 1.5rem;
}

.rt-page-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 3.5vw, 3.7rem);
  line-height: 0.95;
  letter-spacing: -0.05em;
}

.rt-device-tile {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  align-items: center;
  gap: 1rem;
  width: 100%;
  padding: 1rem 1.15rem;
  border: 1px solid rgba(255, 255, 255, 0.72);
  border-radius: 22px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(255, 255, 255, 0.68));
  box-shadow: 0 12px 28px rgba(22, 22, 22, 0.07);
  transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
}

.rt-device-tile:hover {
  transform: translateY(-2px);
  border-color: rgba(255, 79, 18, 0.24);
  box-shadow: 0 18px 34px rgba(22, 22, 22, 0.09);
}

.rt-device-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 52px;
  border-radius: 16px;
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.78);
}

.rt-device-status {
  display: inline-flex;
  align-items: center;
  padding: 0.2rem 0.55rem;
  border-radius: 999px;
  background: rgba(22, 22, 22, 0.06);
  color: var(--muted);
  font-size: 0.72rem;
}

.rt-device-status-online {
  background: rgba(19, 138, 90, 0.12);
  color: var(--success);
}

.rt-subtle {
  color: var(--muted);
}

.rt-animate-up,
.rt-animate-slide-left,
.rt-animate-slide-right {
  opacity: 0;
  animation-duration: 0.85s;
  animation-fill-mode: forwards;
  animation-timing-function: cubic-bezier(0.2, 0.8, 0.2, 1);
  will-change: transform, opacity;
}

.rt-animate-up {
  animation-name: rtRevealUp;
}

.rt-animate-slide-left {
  animation-name: rtRevealLeft;
}

.rt-animate-slide-right {
  animation-name: rtRevealRight;
}

.rt-delay-1 { animation-delay: 0.08s; }
.rt-delay-2 { animation-delay: 0.16s; }
.rt-delay-3 { animation-delay: 0.24s; }
.rt-delay-4 { animation-delay: 0.32s; }
.rt-delay-5 { animation-delay: 0.4s; }

.no-underline {
  text-decoration: none !important;
}

@keyframes rtRevealUp {
  from {
    opacity: 0;
    transform: translateY(32px) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes rtRevealLeft {
  from {
    opacity: 0;
    transform: translateX(-28px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes rtRevealRight {
  from {
    opacity: 0;
    transform: translateX(28px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes rtFloat {
  0%,
  100% {
    transform: translate3d(0, 0, 0);
  }
  50% {
    transform: translate3d(-10px, 10px, 0);
  }
}

@media (max-width: 1024px) {
  .rt-topbar {
    border-radius: 28px;
    flex-wrap: wrap;
  }
}

@media (max-width: 768px) {
  .rt-orbit {
    width: 360px;
    height: 360px;
    right: -140px;
    top: -80px;
  }

  .rt-card,
  .rt-card-soft {
    border-radius: 22px;
  }

  .rt-device-tile {
    grid-template-columns: auto minmax(0, 1fr);
  }
}

@media (prefers-reduced-motion: reduce) {
  .rt-orbit,
  .rt-animate-up,
  .rt-animate-slide-left,
  .rt-animate-slide-right {
    animation: none;
    opacity: 1;
    transform: none;
  }
}
