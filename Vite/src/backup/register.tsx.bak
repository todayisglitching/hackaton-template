import { Button, Card, Checkbox, Chip, Description, Input, Label, Link, TextField, toast } from '@heroui/react';
import { useState } from 'react';
import { useNavigate } from 'react-router-dom';
import { useAuth } from '../../hooks/auth';

function validateEmail(email: string): string | null {
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!email) return 'Email обязателен для заполнения';
  if (!emailRegex.test(email)) return 'Введите корректный email-адрес';
  return null;
}

function validatePassword(password: string): string | null {
  if (!password) return 'Пароль обязателен для заполнения';
  if (password.length < 8) return 'Пароль должен содержать минимум 8 символов';
  if (!/[A-Z]/.test(password)) return 'Добавьте хотя бы одну заглавную букву';
  if (!/[a-z]/.test(password)) return 'Добавьте хотя бы одну строчную букву';
  if (!/\d/.test(password)) return 'Добавьте хотя бы одну цифру';
  return null;
}

const RegisterPage = () => {
  const navigate = useNavigate();
  const { register, isLoading } = useAuth();
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');
  const [acceptTerms, setAcceptTerms] = useState(false);
  const [acceptPrivacy, setAcceptPrivacy] = useState(false);
  const [acceptMarketing, setAcceptMarketing] = useState(false);

  const handleSubmit = async (event: React.FormEvent<HTMLFormElement>) => {
    event.preventDefault();

    const emailError = validateEmail(email.trim());
    if (emailError) {
      toast.warning(emailError);
      return;
    }

    const passwordError = validatePassword(password);
    if (passwordError) {
      toast.warning(passwordError);
      return;
    }

    if (!acceptTerms || !acceptPrivacy) {
      toast.warning('Нужно принять условия и политику приватности.');
      return;
    }

    const result = await register(email.trim(), password);
    if (!result.success) {
      toast.danger(result.error);
      return;
    }

    toast.success('Регистрация завершена. Переходим в USmart.');
    navigate('/dashboard');
  };

  return (
    <div className="rt-auth-grid xl:grid-cols-[1.02fr_0.98fr]">
      <Card className="rt-card overflow-hidden">
        <Card.Content className="p-6 md:p-8">
          <Chip className="rt-pill text-xs">Create account</Chip>
          <div className="mt-5">
            <div className="rt-kicker">Get started</div>
            <h1 className="rt-display mt-3 text-4xl font-semibold">Создайте аккаунт для панели USmart.</h1>
            <p className="mt-4 max-w-xl text-sm leading-relaxed text-[color:var(--muted)] md:text-base">
              После регистрации вы сразу попадаете в демо-интерфейс: устройства, BLE, управление сессиями и заготовка автоматизаций.
            </p>
          </div>

          <form onSubmit={handleSubmit} className="mt-8 space-y-4">
            <TextField name="email" type="email" className="w-full" isRequired>
              <Label>Email</Label>
              <Input
                placeholder="team@usmart.dev"
                value={email}
                onChange={(event) => setEmail(event.target.value)}
                autoComplete="email"
                disabled={isLoading}
              />
            </TextField>

            <TextField name="password" type="password" className="w-full" isRequired>
              <Label>Пароль</Label>
              <Input
                placeholder="Минимум 8 символов"
                value={password}
                onChange={(event) => setPassword(event.target.value)}
                autoComplete="new-password"
                disabled={isLoading}
              />
            </TextField>

            <div className="rounded-[24px] border border-[color:var(--border)] bg-white/70 p-4">
              <div className="space-y-4">
                <Checkbox isSelected={acceptTerms} onChange={setAcceptTerms}>
                  <Checkbox.Control>
                    <Checkbox.Indicator />
                  </Checkbox.Control>
                  <Checkbox.Content>
                    <Label>Принимаю условия использования</Label>
                    <Description>Нужны для работы аккаунта и доступа к хабу.</Description>
                  </Checkbox.Content>
                </Checkbox>

                <Checkbox isSelected={acceptPrivacy} onChange={setAcceptPrivacy}>
                  <Checkbox.Control>
                    <Checkbox.Indicator />
                  </Checkbox.Control>
                  <Checkbox.Content>
                    <Label>Согласен с политикой приватности</Label>
                    <Description>Используем данные только для авторизации и отображения устройств.</Description>
                  </Checkbox.Content>
                </Checkbox>

                <Checkbox isSelected={acceptMarketing} onChange={setAcceptMarketing}>
                  <Checkbox.Control>
                    <Checkbox.Indicator />
                  </Checkbox.Control>
                  <Checkbox.Content>
                    <Label>Хочу получать новости проекта</Label>
                    <Description>Опционально. Нужна только для хакатонной витрины и апдейтов.</Description>
                  </Checkbox.Content>
                </Checkbox>
              </div>
            </div>

            <Button fullWidth className="rt-btn rt-btn-primary" type="submit" isDisabled={isLoading || !acceptTerms || !acceptPrivacy}>
              {isLoading ? 'Создаём аккаунт...' : 'Зарегистрироваться'}
            </Button>
          </form>

          <div className="mt-6 flex flex-wrap items-center justify-between gap-3 text-sm text-[color:var(--muted)]">
            <button type="button" className="transition-colors hover:text-[color:var(--foreground)]" onClick={() => navigate('/auth/login')}>
              Уже есть аккаунт? Войти
            </button>
            <Link href="https://github.com/todayisglitching/hackaton-template" target="_blank" rel="noreferrer">
              Открыть GitHub
            </Link>
          </div>
        </Card.Content>
      </Card>

      <Card className="rt-card-soft overflow-hidden">
        <Card.Content className="flex h-full flex-col justify-between p-6 md:p-8">
          <div>
            <div className="rt-kicker">Why now</div>
            <h2 className="rt-display mt-3 text-3xl font-semibold">Что увидит жюри и пользователь после входа</h2>
            <div className="mt-6 grid gap-4 text-sm text-[color:var(--muted)]">
              <div className="rounded-[20px] border border-[color:var(--border)] bg-white/70 p-4">
                Современный onboarding без сырого стандартного экрана.
              </div>
              <div className="rounded-[20px] border border-[color:var(--border)] bg-white/70 p-4">
                Привязка к backend API из `docs/API.md`: auth, refresh, sessions, devices.
              </div>
              <div className="rounded-[20px] border border-[color:var(--border)] bg-white/70 p-4">
                Основа под следующие этапы: сценарии, роли, ZigBee и Matter.
              </div>
            </div>
          </div>

          <div className="mt-8 rounded-[24px] border border-[color:var(--border)] bg-white/80 p-5 text-sm text-[color:var(--muted)]">
            Подсказка: для демонстрации BLE лучше использовать Chrome или Edge на ноутбуке с включённым Bluetooth.
          </div>
        </Card.Content>
      </Card>
    </div>
  );
};

export default RegisterPage;
