import { NavLink } from 'react-router-dom';

const userNavItems = [
  { to: '/dashboard', label: 'Устройства', exact: true },
  { to: '/dashboard/automation', label: 'Автоматизации' },
  { to: '/dashboard/account', label: 'Аккаунт' },
];

const demoNavItems = [
  { to: '/demo', label: 'Демо-устройства', exact: true },
  { to: '/auth/login', label: 'Войти в кабинет' },
  { to: '/auth/register', label: 'Регистрация' },
];

function navClassName(isActive: boolean) {
  return `rt-nav-link ${isActive ? 'rt-nav-link-active' : ''}`;
}

const Sidebar = ({ mode = 'user' }: { mode?: 'demo' | 'user' }) => {
  const items = mode === 'demo' ? demoNavItems : userNavItems;

  return (
    <aside className="rt-sidebar lg:sticky lg:top-6">
      <div className="rt-card p-5">
        <nav className="grid gap-2">
          {items.map((item) => (
            <NavLink key={item.to} to={item.to} end={item.exact} className={({ isActive }) => navClassName(isActive)}>
              {item.label}
            </NavLink>
          ))}
        </nav>
      </div>

      <div className="rt-card-soft mt-4 p-5">
        <div className="text-sm font-semibold">BLE ready</div>
        <div className="mt-4 grid gap-2 text-sm text-[color:var(--muted)]">
          <div className="flex items-center justify-between gap-3 rounded-[16px] border border-[color:var(--border)] bg-white/60 px-3 py-2">
            <span>BLE</span>
            <span className="text-[color:var(--success)]">Готов</span>
          </div>
          <div className="flex items-center justify-between gap-3 rounded-[16px] border border-[color:var(--border)] bg-white/60 px-3 py-2">
            <span>ZigBee</span>
            <span>Требует станцию</span>
          </div>
          <div className="flex items-center justify-between gap-3 rounded-[16px] border border-[color:var(--border)] bg-white/60 px-3 py-2">
            <span>Matter</span>
            <span>Требует станцию</span>
          </div>
          <div className="flex items-center justify-between gap-3 rounded-[16px] border border-[color:var(--border)] bg-white/60 px-3 py-2">
            <span>Wi-Fi</span>
            <span>Требует станцию</span>
          </div>
        </div>
      </div>
    </aside>
  );
};

export default Sidebar;
