      <section id="demo" className="rt-animate-up rt-delay-2">
        <Card className="rt-card overflow-hidden">
          <Card.Content className="grid gap-8 p-6 md:p-10 xl:grid-cols-[1fr_auto] xl:items-center">
            <div className="rt-animate-slide-left rt-delay-2">
