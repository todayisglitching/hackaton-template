import { Button, Card, Chip, toast } from '@heroui/react';
import { useEffect, useMemo, useState } from 'react';
import { useNavigate } from 'react-router-dom';
import { addDevice, fetchDevices } from '../../api/devices';
import { createBleUiDevice, demoDevices, mapApiDeviceToUi, type UiDevice } from '../../data/devices';
import { connectToDevice, requestKettleDevice, supportsBluetooth } from '../../services/ble';

const icons = {
  relay: (
    <svg viewBox="0 0 24 24" className="h-5 w-5" aria-hidden="true">
      <path d="M12 3v7m4.24-5.24A7 7 0 1 1 7.76 4.76" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" />
    </svg>
  ),
  sensor: (
    <svg viewBox="0 0 24 24" className="h-5 w-5" aria-hidden="true">
      <path d="M12 3a3 3 0 0 0-3 3v7.2a4 4 0 1 0 6 0V6a3 3 0 0 0-3-3z" fill="none" stroke="currentColor" strokeWidth="2" />
    </svg>
  ),
  light: (
    <svg viewBox="0 0 24 24" className="h-5 w-5" aria-hidden="true">
      <path d="M9 18h6m-5 3h4M12 3a6 6 0 0 0-3 11.2V16h6v-1.8A6 6 0 0 0 12 3z" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" />
    </svg>
  ),
};

const HomePage = ({ mode = 'user' }: { mode?: 'demo' | 'user' }) => {
  const navigate = useNavigate();
  const [devices, setDevices] = useState<UiDevice[]>([]);
  const [selectedRoom, setSelectedRoom] = useState<string>('Все');
  const [isFetching, setIsFetching] = useState(true);
  const [isConnecting, setIsConnecting] = useState(false);
  const [bleStatus, setBleStatus] = useState('Готов к подключению через Web Bluetooth');
  const [sourceLabel, setSourceLabel] = useState<'api' | 'demo'>('demo');

  useEffect(() => {
    let mounted = true;

    if (mode === 'demo') {
      setDevices(demoDevices);
      setSourceLabel('demo');
      setIsFetching(false);
      return () => {
        mounted = false;
      };
    }

    const loadDevices = async () => {
      setIsFetching(true);
      try {
        const response = await fetchDevices();
        const mapped = response.devices.map(mapApiDeviceToUi);
        if (!mounted) {
          return;
        }

        setDevices(mapped);
        setSourceLabel('api');
      } catch (error) {
        console.error(error);
        if (mounted) {
          setDevices([]);
          setSourceLabel('api');
          setBleStatus('API устройств недоступно или вернуло ошибку.');
        }
      } finally {
        if (mounted) {
          setIsFetching(false);
        }
      }
    };

    void loadDevices();

    return () => {
      mounted = false;
    };
  }, [mode]);

  const rooms = useMemo(() => ['Все', ...new Set(devices.map((device) => device.room))], [devices]);

  const visibleDevices = useMemo(() => {
    if (selectedRoom === 'Все') {
      return devices;
    }

    return devices.filter((device) => device.room === selectedRoom);
  }, [devices, selectedRoom]);

  const stats = useMemo(() => {
    const online = devices.filter((device) => device.status === 'online').length;
    const roomsCount = new Set(devices.map((device) => device.room)).size;
    const bleCount = devices.filter((device) => device.source === 'ble').length;

    return [
      { label: 'Всего устройств', value: devices.length },
      { label: 'Онлайн', value: online },
      { label: 'Комнат', value: roomsCount },
      { label: 'BLE сейчас', value: bleCount },
    ];
  }, [devices]);

  const handleAddDevice = async () => {
    if (!supportsBluetooth()) {
      setBleStatus('Bluetooth доступен только в Chromium-браузерах с включённым BLE.');
      toast.warning('Откройте демо в Chrome, Edge или Opera.');
      return;
    }

    setIsConnecting(true);
    setBleStatus('Открываем системное окно BLE...');

    try {
      const bluetoothDevice = await requestKettleDevice();
      const localDevice = createBleUiDevice(bluetoothDevice);

      setDevices((prev) => [localDevice, ...prev.filter((device) => device.deviceKey !== localDevice.deviceKey)]);
      setBleStatus(`Найдено устройство: ${bluetoothDevice.name || 'BLE Device'}`);

      await connectToDevice(bluetoothDevice, (value) => {
        setDevices((prev) =>
          prev.map((device) =>
            device.deviceKey === bluetoothDevice.id ? { ...device, lastValue: value, status: 'online' } : device
          )
        );
      });

      if (mode === 'demo') {
        setBleStatus('Устройство подключено в публичном демо.');
        toast.success('BLE-устройство подключено в демо-режиме.');
        return;
      }

      try {
        const created = await addDevice({
          deviceId: bluetoothDevice.id,
          name: bluetoothDevice.name || 'BLE Device',
          type: 'ble-relay',
          location: 'BLE bridge',
          manufacturer: 'Web Bluetooth',
          model: 'Chromium Device',
          firmwareVersion: '',
          properties: JSON.stringify({ description: 'Добавлено через браузер и сохранено в API.' }),
        });

        const mapped = mapApiDeviceToUi(created);
        setDevices((prev) => [mapped, ...prev.filter((device) => device.deviceKey !== bluetoothDevice.id)]);
        setSourceLabel('api');
        setBleStatus('Устройство подключено и сохранено в backend.');
        toast.success('BLE-устройство добавлено в кабинет.');
      } catch (error) {
        console.error(error);
        setBleStatus('Устройство подключено локально, но backend не сохранил его.');
        toast.warning('BLE работает локально, но сохранить устройство в API не удалось.');
      }
    } catch (error) {
      console.error(error);
      setBleStatus('Не удалось подключить BLE-устройство.');
      toast.danger('Подключение BLE прервано или устройство не ответило.');
    } finally {
      setIsConnecting(false);
    }
  };

  const backRoute = mode === 'demo' ? '/demo' : '/dashboard';

  return (
    <div className="space-y-6">
      <Card className="rt-card overflow-hidden">
        <Card.Content className="grid gap-6 p-6 md:p-8 xl:grid-cols-[1.1fr_0.9fr] xl:items-end">
          <div>
            <div className="rt-kicker">{mode === 'demo' ? 'Public demo' : 'Dashboard'}</div>
            <h1 className="rt-display mt-3 text-4xl font-semibold">
              {mode === 'demo' ? 'Демо-панель устройств без входа.' : 'Устройства пользователя в отдельном кабинете.'}
            </h1>
            <p className="mt-4 max-w-3xl text-sm leading-relaxed text-[color:var(--muted)] md:text-base">
              {mode === 'demo'
                ? 'Здесь живёт открытый сценарий для защиты: мок-устройства и BLE-подключение без авторизации.'
                : 'Этот раздел работает только с реальными устройствами пользователя через backend API и BLE-добавление в кабинет.'}
            </p>
            <div className="mt-5 flex flex-wrap gap-2">
              <Chip className="rt-pill text-xs">Источник: {sourceLabel === 'api' ? 'backend API' : 'публичное демо'}</Chip>
              <Chip className="rt-pill text-xs">{bleStatus}</Chip>
            </div>
          </div>

          <div className="flex flex-col gap-3 sm:flex-row xl:justify-end">
            <Button className="rt-btn rt-btn-primary" onClick={handleAddDevice} isDisabled={isConnecting}>
              {isConnecting ? 'Подключаем...' : 'Подключить BLE'}
            </Button>
            {mode === 'demo' ? (
              <Button className="rt-btn rt-btn-secondary" onClick={() => navigate('/auth/login')}>
                Войти в кабинет
              </Button>
            ) : (
              <Button className="rt-btn rt-btn-secondary" onClick={() => navigate('/dashboard/account')}>
                Открыть сессии
              </Button>
            )}
          </div>
        </Card.Content>
      </Card>

      <div className="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {stats.map((item) => (
          <Card key={item.label} className="rt-card-soft">
            <Card.Content className="p-5">
              <div className="text-sm text-[color:var(--muted)]">{item.label}</div>
              <div className="mt-2 text-3xl font-semibold">{item.value}</div>
            </Card.Content>
          </Card>
        ))}
      </div>

      {isFetching ? (
        <Card className="rt-card p-8 text-sm text-[color:var(--muted)]">Загружаем устройства...</Card>
      ) : visibleDevices.length === 0 ? (
        <Card className="rt-card p-8 text-sm text-[color:var(--muted)]">
          <div className="font-semibold text-[color:var(--foreground)]">Устройств пока нет.</div>
          <div className="mt-2">Подключите BLE-чайник или добавьте устройство через backend, чтобы увидеть его здесь.</div>
        </Card>
      ) : (
        <div className="space-y-3">
          <div className="flex items-center justify-between gap-3">
            <div className="text-sm font-medium text-[color:var(--muted)]">Категории</div>
            <div className="flex max-w-full flex-1 justify-end gap-2 overflow-x-auto pb-1">
              {rooms.map((room) => (
                <button
                  key={room}
                  type="button"
                  className={`rt-chip shrink-0 transition-colors ${selectedRoom === room ? 'border-[color:var(--accent)] bg-[color:var(--accent-soft)]' : ''}`}
                  onClick={() => setSelectedRoom(room)}
                >
                  {room}
                </button>
              ))}
            </div>
          </div>

          <div className="grid gap-3 md:grid-cols-2 2xl:grid-cols-3">
            {visibleDevices.map((device) => (
              <button
                key={device.deviceKey}
                type="button"
                className="rt-device-tile text-left"
                onClick={() => navigate(`${backRoute}/device/${device.deviceKey}`, { state: { device } })}
              >
                <div className="rt-device-icon">{icons[device.kind]}</div>
                <div className="min-w-0">
                  <div className="flex flex-wrap items-center gap-2">
                    <span className="truncate text-base font-semibold">{device.name}</span>
                    <span className={`rt-device-status ${device.status === 'online' ? 'rt-device-status-online' : ''}`}>
                      {device.status === 'online' ? 'Онлайн' : 'Оффлайн'}
                    </span>
                  </div>
                  <div className="mt-1 text-sm text-[color:var(--muted)]">{device.room}</div>
                  <div className="mt-2 flex flex-wrap gap-2 text-xs">
                    {device.capabilities.slice(0, 3).map((capability) => (
                      <span key={capability} className="rt-chip">
                        {capability}
                      </span>
                    ))}
                  </div>
                </div>
                <div className="text-right">
                  <div className="text-xs text-[color:var(--muted)]">Температура</div>
                  <div className="mt-1 text-xl font-semibold">
                    {device.lastValue !== undefined ? `${device.lastValue}${device.kind === 'sensor' ? '°' : ''}` : '--'}
                  </div>
                </div>
              </button>
            ))}
          </div>
        </div>
      )}
    </div>
  );
};

export default HomePage;
