import { Button, Card, Chip, Input, Label, TextField, toast } from '@heroui/react';
import { useState } from 'react';
import { useNavigate } from 'react-router-dom';
import { useAuth } from '../../hooks/auth';

const LoginPage = () => {
  const navigate = useNavigate();
  const { login, isLoading } = useAuth();
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');

  const handleSubmit = async (event: React.FormEvent<HTMLFormElement>) => {
    event.preventDefault();

    const result = await login(email.trim(), password);
    if (!result.success) {
      toast.danger(result.error);
      return;
    }

    toast.success('Успешный вход. Добро пожаловать в USmart.');
    navigate('/dashboard');
  };

  return (
    <div className="rt-auth-shell xl:grid-cols-[0.95fr_1.05fr]">
      <Card className="rt-card overflow-hidden">
        <Card.Content className="p-6 md:p-8">
          <Chip className="rt-pill text-xs">Sign in</Chip>
          <div className="mt-5">
            <div className="rt-kicker">Smart Home Control</div>
            <h1 className="rt-display mt-3 text-4xl font-semibold">Вход в хаб управления домом.</h1>
            <p className="mt-4 max-w-xl text-sm leading-relaxed text-[color:var(--muted)] md:text-base">
              Внутри: список устройств, BLE-подключение, сессии пользователя и заготовка под автоматизации.
            </p>
          </div>

          <form onSubmit={handleSubmit} className="mt-8 space-y-4">
            <TextField name="email" type="email" className="w-full" isRequired>
              <Label>Email</Label>
              <Input
                placeholder="team@usmart.dev"
                value={email}
                onChange={(event) => setEmail(event.target.value)}
                autoComplete="email"
                disabled={isLoading}
              />
            </TextField>

            <TextField name="password" type="password" className="w-full" isRequired>
              <Label>Пароль</Label>
              <Input
                placeholder="Введите пароль"
                value={password}
                onChange={(event) => setPassword(event.target.value)}
                autoComplete="current-password"
                disabled={isLoading}
              />
            </TextField>

            <Button fullWidth className="rt-btn rt-btn-primary" type="submit" isDisabled={isLoading}>
              {isLoading ? 'Входим...' : 'Войти'}
            </Button>
          </form>

          <div className="mt-6 flex flex-wrap items-center justify-between gap-3 text-sm">
            <button type="button" className="text-[color:var(--muted)] transition-colors hover:text-[color:var(--foreground)]" onClick={() => navigate('/auth/register')}>
              Нет аккаунта? Зарегистрироваться
            </button>
            <button type="button" className="text-[color:var(--muted)] transition-colors hover:text-[color:var(--foreground)]" onClick={() => navigate('/')}>
              Назад на лендинг
            </button>
          </div>
        </Card.Content>
      </Card>

      <Card className="rt-card-soft overflow-hidden">
        <Card.Content className="flex h-full flex-col justify-between p-6 md:p-8">
          <div>
            <div className="rt-kicker">What you get</div>
            <div className="mt-4 space-y-4">
              <div className="rounded-[20px] border border-[color:var(--border)] bg-white/70 p-4">
                <div className="text-lg font-semibold">Единая панель устройств</div>
                <div className="mt-2 text-sm text-[color:var(--muted)]">Состояние, комнаты, быстрые действия и переход в карточку устройства.</div>
              </div>
              <div className="rounded-[20px] border border-[color:var(--border)] bg-white/70 p-4">
                <div className="text-lg font-semibold">Живое BLE-подключение</div>
                <div className="mt-2 text-sm text-[color:var(--muted)]">Web Bluetooth API для Chromium и локальное добавление устройств в систему.</div>
              </div>
              <div className="rounded-[20px] border border-[color:var(--border)] bg-white/70 p-4">
                <div className="text-lg font-semibold">Безопасность</div>
                <div className="mt-2 text-sm text-[color:var(--muted)]">JWT, refresh token и управление активными сессиями прямо из профиля.</div>
              </div>
            </div>
          </div>

          <div className="mt-8 rounded-[24px] bg-[color:var(--accent-soft)] p-5 text-sm text-[color:var(--foreground)]">
            Хакатонный фокус: быстро показать ценность универсального протокола, а не только красивый маркетинговый экран.
          </div>
        </Card.Content>
      </Card>
    </div>
  );
};

export default LoginPage;
